# Local development only. The evaluation harness injects these at runtime;
# do NOT bundle a real .env into the Docker image (.dockerignore excludes it).
#
# Copy to .env and fill in your dev values:
#   cp .env.example .env

FIREWORKS_API_KEY=your_dev_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Comma-separated, cost-ordered (cheapest first). The harness injects the real
# scored list at eval time; these are the models available for dev on this key.
ALLOWED_MODELS=accounts/fireworks/models/gpt-oss-120b,accounts/fireworks/models/glm-5p1,accounts/fireworks/models/glm-5p2,accounts/fireworks/models/kimi-k2p5,accounts/fireworks/models/deepseek-v4-pro,accounts/fireworks/models/kimi-k2p6
